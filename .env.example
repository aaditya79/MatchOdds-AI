# Copy this file to .env (gitignored) and fill in your keys.
# Pipelines and agents auto-load via python-dotenv.

# Anthropic Claude — required for agents, debate, CoT, backtest
ANTHROPIC_API_KEY=

# The Odds API (free tier) — required for live odds in nba_odds_pipeline.py
# Get one at https://the-odds-api.com
ODDS_API_KEY=

# YouTube Data API v3 — required for nba_youtube_pipeline.py
# Get one at https://console.cloud.google.com (enable "YouTube Data API v3", then create API key)
YOUTUBE_API_KEY=

# Optional: OpenAI fallback for agents/CoT/debate
# OPENAI_API_KEY=
